# Server
NODE_ENV=development
PORT=5000

# Database — value here targets a host-installed Mongo.
# Under Docker Compose this is overridden to mongodb://mongo:27017/tuition_finder
# (see docker-compose.yml).
MONGO_URI=mongodb://127.0.0.1:27017/tuition_finder

# Auth (placeholders — wired in Phase 2)
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Admin seeder — used by `npm run seed:admin` to bootstrap the first admin.
# No public admin register exists; this script is the only way in.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Root Admin
