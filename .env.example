# Server
NODE_ENV=development
PORT=5000

# Database — value here targets a host-installed Mongo.
# Under Docker Compose this is overridden to mongodb://mongo:27017/tuition_finder
# (see docker-compose.yml).
MONGO_URI=mongodb://127.0.0.1:27017/tuition_finder

# Auth — access + refresh JWTs use SEPARATE secrets (limits blast radius if one leaks).
# Both must be set; refresh must differ from access. Use long random strings.
JWT_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_DIFFERENT_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis — backs the refresh-token whitelist + family-tracking for rotation.
# Compose override: redis://redis:6379 (see docker-compose.yml).
REDIS_URL=redis://127.0.0.1:6379

# Cookie — refresh tokens are delivered as HTTP-only cookies scoped to /api/auth.
# Leave COOKIE_DOMAIN unset for "same-origin only" (recommended for dev).
COOKIE_DOMAIN=

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Admin seeder — used by `npm run seed:admin` to bootstrap the first admin.
# No public admin register exists; this script is the only way in.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Root Admin

# Logging — trace|debug|info|warn|error|fatal
# Default: info in production, debug otherwise.
LOG_LEVEL=debug
